{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint --max-warnings 0 --no-warn-ignored",
    "lint:pre-commit": "pnpm lint",
    "fmt": "prettier --write \"./*.{js,ts,jsx,tsx}\" \"./**/*.{js,ts,jsx,tsx}\"",
    "fmt:ci": "prettier --check \"./*.{js,ts,jsx,tsx}\" \"./**/*.{js,ts,jsx,tsx}\"",
    "fmt:pre-commit": "prettier --check",
    "typecheck": "tsc --build",
    "deps:circular": "madge --circular .",
    "deps:unused": "knip --include dependencies,files",
    "prepare": "husky",
    "test:gherkin": "TEST=gherkin bash e2e/script/runTest.sh",
    "test:playwright": "NODE_TLS_REJECT_UNAUTHORIZED=0 TEST=playwright bash e2e/script/runTest.sh",
    "fmt:gherkin": "gherlint e2e/tests/e2e/features -c .gherlintrc.json",
    "fmt:gherkin-fix": "gherlint --fix e2e/tests/e2e/features -c .gherlintrc.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@cucumber/cucumber": "^12.1.0",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.53.2",
    "@types/node": "^24.0.8",
    "@gherlint/gherlint": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "eslint": "^9.32.0",
    "husky": "^9.1.7",
    "knip": "^5.62.0",
    "licensee": "^11.1.1",
    "lint-staged": "^16.1.4",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.38.0",
    "globals": "^16.3.0",
    "@types/pngjs": "^6.0.5"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "fast-xml-parser": "^5.7.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "uuid": "^14.0.0"
  }
}
